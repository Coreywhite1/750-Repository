#QUESTION 2 ----
dfnate <- read_csv('kSCt4.csv')
natemutate <- dfnate |>
mutate(date1 = as.Date(modeldate, format = '%m/%d/%Y'))
#making the plot
plotnate <- natemutate |>
ggplot(aes(x = date1, y = approve )) +
geom_line(aes( y = approve_lo, linetype = 'approve_lo', linewidth = 'approve_lo'), color = 'lightblue') +
geom_line(aes( y = approve_hi, linetype = 'approve_hi', linewidth = 'approve_hi' ), color = 'lightblue')+
geom_line(aes( y = approve, linetype = 'approve', linewidth = 'approve'), color = 'lightblue4')+
geom_line(aes( y = disapprove, linetype = 'disapprove', linewidth = 'disapprove'), color = 'orange3') +
geom_line(aes( y = disapprove_lo, linetype = 'disapprove_lo', linewidth = 'disapprove_lo'), color = 'orange') +
geom_line(aes( y = disapprove_hi, linetype =  'disapprove_hi', linewidth = 'disapprove_hi'), color = 'orange') +
geom_ribbon(aes(ymin = approve_lo, ymax = approve_hi), fill = 'lightblue3', alpha = .5 )+
geom_ribbon(aes(ymin = disapprove_lo, ymax = disapprove_hi), fill = 'salmon2', alpha = .5) +
geom_hline(yintercept = 50, color = 'black', linetype = 'solid', size = .5)+
scale_linetype_manual(
values = c(
approve = 'solid',
approve_lo = 'dotted',
approve_hi = 'dotted',
disapprove = 'solid',
disapprove_lo ='dotted',
disapprove_hi = 'dotted'
)) +
scale_linewidth_manual(values = c(
approve = 1,
approve_lo = 1,
disapprove = 1,
disapprove_lo =1,
disapprove_hi =1,
approve_hi = 1
)) +
scale_x_date(
date_breaks = '3 months',
date_labels = '%b',
expand = expansion(mult = c(0, .01))
)+
scale_y_continuous(
limits = c(30, 70),
expand = expansion(mult = c(0, .01))
) +
labs(
title = 'Do Americans approve or disapprove of Donald Trump?',
subtitle = 'An updating polling average of Donald Trumps approval rating and disapproval rating in his second term, accounting
for each polls quality, recency, sample size, and partisan lean',
caption = 'Note: 90% of polls are projected to fall within the shaded regions.'
) +
theme(
legend.position = 'none',
panel.grid.major = element_line(color = 'lightgrey'),
panel.grid.minor = element_blank(),
panel.background = element_rect(fill = 'white'),
title = element_text(face = 'bold', size = 18),
plot.subtitle = element_text(face = 'plain', size = 12),
axis.title.x = element_blank(),
axis.title.y = element_blank(),
axis.text = element_text(colour = 'darkgrey'),
scale_x_continuous(
labels = c('Apr\2025', 'Jul', 'Oct', 'Jan\2026')
),
plot.caption = element_text(size = 9, face = 'italic', hjust = 0)
)
(plotnate)
