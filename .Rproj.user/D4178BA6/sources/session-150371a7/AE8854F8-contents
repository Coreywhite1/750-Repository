library(tidyverse)
library(knitr)
library(readxl) #for reading excel files 
#read in data from excel
dataweek <- read_excel('sharegreen.xlsx', sheet = 'Data') |>
  filter(!is.na(City))
#reads the data with the second sheet titled data and removes NA cities in the code

#transform-----
#create new variables with mutate
#create rename and select all in one

#create new variable

dataweek2 <- dataweek |>
  mutate(
    city = City, #renames renames variables
    green_chg = Green2020 - Green1990, #caluclate new var from old
    green_goal = if_else(Green2020 > 20, 'Met', 'Not'),
    .before = 1  
  )
#basic stats
#+
