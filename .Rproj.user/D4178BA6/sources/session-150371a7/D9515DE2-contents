Question 9
```{r}
wordletable3 <- wordletable |>
  semi_join(wordletable2, by = "letter")
wordletable4 <- wordletable2 |>
  left_join(wordletable, by = "letter") |>
  filter(dups != TRUE)
wordlescores <- wordletable4 |>
  group_by(word) |>
  summarise(points = sum(n) )|>
  arrange(desc(points))
topscore <- wordlescores |>
  slice_max(points, n = 10)
bottomscore <- wordlescores |>
  slice_min(points, n =17)
#printing the top 10 scoring words and the 17 words tied for lowest scoring
Scorecard <- bind_rows(topscore, bottomscore)
print(Scorecard, n = Inf)
```

