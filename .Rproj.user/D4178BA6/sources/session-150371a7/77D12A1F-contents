#this function will return median values for a dataset.
medians2 <- function(data, grouping, var) {
  tibble1 <-
    data |>
    group_by({{ grouping }}) |>
    summarize(
      medians = median({{ var }}, na.rm = T)
    ) |>
    kable(
      digits = 1L,
      caption = rlang::englue("Mean of {{var}} by {{grouping}}")
    )
  return(tibble1)
}
