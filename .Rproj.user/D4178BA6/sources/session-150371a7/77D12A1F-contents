# Senators and their bills.

get_senator_info <- function(links2) {
  
  # Be polite — wait a random amount between requests
  Sys.sleep(runif(1, 2, 5))
  
  tryCatch({
    
    browser$Network$enable()
    browser$Page$navigate(links2)
    Sys.sleep(10)
    
    # 119th congress
    browser$Runtime$evaluate("
      var dropdowns = document.querySelectorAll('select');
      dropdowns.forEach(function(d) {
        for (var i = 0; i < d.options.length; i++) {
          if (d.options[i].text.includes('119')) {
            d.value = d.options[i].value;
            d.dispatchEvent(new Event('change', {bubbles:true}));
            break;
          }
        }
      });
    ")
    Sys.sleep(8)
    
    # Wait until "Bills Sponsored" appears on the page
    for (try in 1:5) {
      found <- browser$Runtime$evaluate(
        "document.body.innerText.includes('Bills Sponsored') ? 'yes' : 'no'"
      )$result$value
      if (found == "yes") break
      Sys.sleep(5)
    }
    
    # Grab all the text from the page
    page_text <- browser$Runtime$evaluate(
      "document.body.innerText"
    )$result$value
    
    # ── Read the bill count ───────────────────────────────────────────
    # Looks for "Bills Sponsored: 34" and grabs the number
    n_bills <- str_match(page_text, "Bills Sponsored:\\s*(\\d+)")[,2] |> as.integer()
    
    # ── Read the top legislative topic ────────────────────────────────
    # Tries "Legislative Topics" first (specific topics like
    # "Mental health"), then "Policy Areas" as backup (broad topics
    # like "Health")
    top_topic <- NA_character_
    
    # Try Legislative Topics first
    lt <- str_match(
      page_text,
      "Commonly Sponsored Bill Legislative Topics:\\s*\\n([^\\n]+)"
    )
    if (!is.na(lt[1, 2]) && nchar(str_trim(lt[1, 2])) > 0) {
      top_topic <- str_trim(lt[1, 2])
    }
    
    # If no Legislative Topics found, try Policy Areas
    if (is.na(top_topic)) {
      pa <- str_match(
        page_text,
        "Commonly Sponsored Bill Policy Areas:\\s*\\n([^\\n]+)"
      )
      if (!is.na(pa[1, 2]) && nchar(str_trim(pa[1, 2])) > 0) {
        top_topic <- str_trim(pa[1, 2])
      }
    } 
    tibble(bills = n_bills, topic = top_topic)
  }, error = function(e) {
    tibble(bills = NA_integer_, topic = NA_character_)
})
}
tableview<-map_dfr(links2, get_senator_info)

#combining the table
senatorstable <- tibble(
  name = names2,
  party = party,
  state = states,
  link = links2,
) |>
  bind_cols(tableview) |>
  clean_names()

View(senatorstable)
write_xlsx(senatorstable, path ='senatorstable.xlsx')

